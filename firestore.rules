rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Baca: user sendiri atau admin
      allow read: if isOwner(userId) || isAdmin();

      // Buat: user sendiri (saat register)
      allow create: if isOwner(userId);

      // Update: user sendiri ATAU admin (untuk verifikasi teknisi)
      allow update: if isOwner(userId) || isAdmin();
    }

    // ── Bookings ───────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.technicianId == request.auth.uid ||
         isAdmin());

      allow create: if isSignedIn();

      allow update: if isSignedIn() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.technicianId == request.auth.uid ||
         isAdmin());
    }

    // ── Technicians online (geo-query) ────────────────────────────
    match /technicians_online/{techId} {
      allow read: if isSignedIn();
      allow write: if isOwner(techId) || isAdmin();
    }

    // ── Technicians (stats backup) ─────────────────────────────────
    match /technicians/{techId} {
      allow read: if isSignedIn();
      allow write: if isOwner(techId) || isAdmin();
    }

    // ── Chats ──────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Create: siapapun yang login (saat buat pre-booking chat baru)
      allow create: if isSignedIn();

      // Read/update/delete: peserta chat. resource bisa null saat doc belum ada.
      allow read, update, delete: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
      }
    }

    // ── Notifications ──────────────────────────────────────────────
    match /notifications/{userId}/items/{itemId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
